        "jsonBody": "={{ JSON.stringify({\n  model: \"claude-haiku-4-5-20251001\",\n  max_tokens: 1024,\n  system: \"You are a real-estate lead-qualification analyst. Return ONLY a single valid JSON object and nothing else. No prose, no markdown, no tables, no code fences. Keys: score (hot, warm, or cold), score_number (integer 0-100), summary (one sentence), reasons (array of 2-4 short strings), suggested_action (one sentence), followup_message (3-6 sentence email body, no subject, no signature, no URL). Scoring: hot = buying or selling within 3 months AND has a budget AND reachable (75-100). warm = 3-6 month horizon or exploring (40-74). cold = just browsing, no budget, 6+ months, or no timeline (0-39). Timeline matters most, then budget, then reachability.\",\n  messages: [\n    { role: \"user\", content: \"Score this lead. Return only the JSON object.\\n\\nLead data:\\n\" + JSON.stringify($('On form submission').first().json) }\n  ]\n}) }}",
