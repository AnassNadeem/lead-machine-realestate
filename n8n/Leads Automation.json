        "jsCode": "const res = $input.first().json;\nlet text = '';\ntry { text = res.content[0].text; } catch (e) { text = ''; }\n\nlet parsed;\ntry {\n  const match = text.match(/\\{[\\s\\S]*\\}/);   // grab the JSON object only\n  parsed = JSON.parse(match ? match[0] : text);\n} catch (e) {\n  parsed = { score:'warm', score_number:50, summary:'PARSE FAILED - check HTTP node',\n             reasons:'parse error', suggested_action:'Review manually', followup_message:'' };\n}\nif (Array.isArray(parsed.reasons)) parsed.reasons = parsed.reasons.join('; ');\nreturn [{ json: { ...$('On form submission').first().json, ...parsed } }];"
