# Copy to .env and fill in. The real .env is git-ignored.
# Canonical credentials live in n8n's credential store.

# Airtable Personal Access Token
AIRTABLE_TOKEN=
# Cal.com discovery-call booking link
CAL_BOOKING_URL=
# Gmail SMTP app password
GMAIL_APP_PASSWORD=
# Anthropic API key (Claude scoring node)
ANTHROPIC_API_KEY=
# n8n production webhook URL (landing form posts here)
N8N_WEBHOOK_URL=
# Airtable base + table for the Leads table
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Leads
